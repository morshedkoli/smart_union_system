# =============================================================================
# SMART UNION PARISHAD MANAGEMENT SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------

# MongoDB Connection URI (Production)
# Format: mongodb://username:password@host:port/database?options
# Example: mongodb://admin:password@localhost:27017/smart_union?authSource=admin
MONGODB_URI=mongodb://localhost:27017/smart_union

# For MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_union?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------

# JWT Secret Key - MUST be at least 32 characters long
# Generate a strong secret: openssl rand -base64 32
# WARNING: Changing this will invalidate all existing tokens
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------

# Environment Mode
NODE_ENV=development
# NODE_ENV=production

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://smartunion.gov.bd

# -----------------------------------------------------------------------------
# OPTIONAL CONFIGURATION
# -----------------------------------------------------------------------------

# Rate Limiting (Optional - defaults are set in code)
# RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
# RATE_LIMIT_MAX_REQUESTS=100

# Redis Configuration (Optional - for distributed rate limiting)
# REDIS_URL=redis://localhost:6379

# Email Configuration (Optional - for password reset and notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@smartunion.gov.bd

# SMS Gateway Configuration (Optional - for notifications)
# SMS_API_KEY=your-sms-api-key
# SMS_API_URL=https://api.sms-provider.com/send

# File Upload Configuration (Optional)
# MAX_FILE_SIZE=5242880  # 5MB in bytes
# UPLOAD_DIR=/var/uploads

# -----------------------------------------------------------------------------
# DEVELOPMENT ONLY (DO NOT USE IN PRODUCTION)
# -----------------------------------------------------------------------------

# SQLite Database (Deprecated - only for legacy compatibility)
# DATABASE_URL="file:./dev.db"

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# 
# [ ] Set NODE_ENV=production
# [ ] Change JWT_SECRET to a strong random value (min 32 chars)
# [ ] Set MONGODB_URI to production database
# [ ] Set NEXT_PUBLIC_APP_URL to production domain
# [ ] Configure SMTP for email notifications
# [ ] Configure SMS gateway for notifications
# [ ] Set up Redis for distributed rate limiting (if multi-server)
# [ ] Configure file upload directories and limits
# [ ] Enable HTTPS (SSL certificate)
# [ ] Set up database backups
# [ ] Configure monitoring and logging
# [ ] Test all critical functionality
# 
# =============================================================================
